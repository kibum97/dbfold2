{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Remote Debug",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/MCPU2/build/MCPU2",
            "args": ["/n/home01/kibumpark/pkg/dbfold2/examples/chignolin/config.yaml"],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/MCPU2/build",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "/usr/bin/gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "build",
            "logging": {
                "engineLogging": true
            }
        }
    ]
}
