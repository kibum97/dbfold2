# 1. Compiler and Flags
CXX      = mpicxx
CXXFLAGS = -O3 -Wall -DDEBUG -Iinclude -std=c++17
LIBS     = -lm

# 2. Directories
SRCDIR = src
INCDIR = include
OBJDIR = build
BINDIR = bin

# 3. Identify Source and Object Files
SRCS = $(wildcard $(SRCDIR)/*.cpp)
OBJS = $(SRCS:$(SRCDIR)/%.cpp=$(OBJDIR)/%.o)

TARGET = $(BINDIR)/mcpu

# 4. Rules
all: $(OBJDIR) $(BINDIR) $(TARGET)

# Create directories if they don't exist
$(OBJDIR) $(BINDIR):
	mkdir -p $@

# Linking
$(TARGET): $(OBJS)
	$(CXX) $(CXXFLAGS) -o $(TARGET) $(OBJS) $(LIBS)

# Compilation
$(OBJDIR)/%.o: $(SRCDIR)/%.cpp
	$(CXX) $(CXXFLAGS) -c $< -o $@

clean:
	rm -rf $(OBJDIR) $(BINDIR)

.PHONY: all clean